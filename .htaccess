# Block direct HTTP access to local secrets (same directory as index.php).
<Files "secrets.local.php">
	Require all denied
</Files>

<IfModule mod_headers.c>
	Header set X-Content-Type-Options "nosniff"
	Header set X-Frame-Options "SAMEORIGIN"
	Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteRule ^map/?$ /maps/ [R=301,L]
	RewriteRule ^maps/satellite/?$ /maps/ [R=301,L]
	RewriteRule ^trees/?$ /maps/trees/ [R=301,L]
	RewriteRule ^resettled/?$ /maps/resettled/ [R=301,L]
	RewriteRule ^gallery-days\.php$ /gallery.php [R=301,L]
	RewriteRule ^slider\.php$ /slideshow.php [R=301,L]
</IfModule>
