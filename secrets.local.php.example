<?php
/**
 * Local dev: copy to secrets.local.php in the site root (next to index.php).
 * Production: GitHub Actions generates secrets.local.php on deploy from repository secrets
 * (see README — Deploy on push). This example is not deployed as-is.
 *
 * Loaded by lib/env.php (bootstrap, Maps-only pages, etc.). Gitignored; blocked by root .htaccess.
 *
 * Put AWS keys, Google Maps API key, and any other local secrets here — not in git.
 *
 * Set both putenv() and $_ENV: on some PHP-FPM hosts getenv() does not see putenv() alone,
 * which would make the AWS SDK fall through to the EC2 metadata service and time out.
 */

// AWS — required for gallery/S3 (lib/bootstrap.php)
$key = 'YOUR_ACCESS_KEY_ID';
$secret = 'YOUR_SECRET_ACCESS_KEY';
$region = 'us-east-1';

putenv('AWS_ACCESS_KEY_ID=' . $key);
putenv('AWS_SECRET_ACCESS_KEY=' . $secret);
putenv('AWS_DEFAULT_REGION=' . $region);
$_ENV['AWS_ACCESS_KEY_ID'] = $key;
$_ENV['AWS_SECRET_ACCESS_KEY'] = $secret;
$_ENV['AWS_DEFAULT_REGION'] = $region;

// Google Maps JavaScript API (browser key) — index.php photo map
$googleMapsKey = 'YOUR_GOOGLE_MAPS_BROWSER_KEY';
putenv('GOOGLE_MAPS_API_KEY=' . $googleMapsKey);
$_ENV['GOOGLE_MAPS_API_KEY'] = $googleMapsKey;

// Mapbox GL public token (pk.*) — maps/ and index.php photo map
$mapboxToken = 'YOUR_MAPBOX_PUBLIC_TOKEN';
putenv('MAPBOX_ACCESS_TOKEN=' . $mapboxToken);
$_ENV['MAPBOX_ACCESS_TOKEN'] = $mapboxToken;

// Optional analytics (omit both for no tracking):
// GoatCounter — free for personal/non-commercial sites: https://www.goatcounter.com
// $goatcounterSite = 'YOUR_SITE_CODE';
// putenv('GOATCOUNTER_SITE_CODE=' . $goatcounterSite);
// $_ENV['GOATCOUNTER_SITE_CODE'] = $goatcounterSite;

// Cloudflare Web Analytics — free, no cookies: https://www.cloudflare.com/web-analytics/
// $cfAnalyticsToken = 'YOUR_CF_BEACON_TOKEN';
// putenv('CLOUDFLARE_WEB_ANALYTICS_TOKEN=' . $cfAnalyticsToken);
// $_ENV['CLOUDFLARE_WEB_ANALYTICS_TOKEN'] = $cfAnalyticsToken;
